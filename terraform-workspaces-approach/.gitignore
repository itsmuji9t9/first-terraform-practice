# ==========================================
# 1. Ignore Terraform Plugins and Temp Files
# ==========================================
.terraform/

# ==========================================
# 2. Ignore Local State Files and Backups
# (These files contain live infrastructure details)
# ==========================================
*.tfstate
*.tfstate.*

# ==========================================
# 3. Ignore Workspace Folder
# (This folder has separate state files for dev, prod, and test)
# ==========================================
.terraform.tfstate.d/
terraform.tfstate.d/

# ==========================================
# 4. Ignore Variables Files
# (These files contain sensitive details like AMI IDs, passwords, etc.)
# ==========================================
*.tfvars
*.tfvars.json

# ==========================================
# 5. Ignore Logs and Settings
# ==========================================
.terraformrc
terraform.rc
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json